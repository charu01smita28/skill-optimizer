# Runtime configuration.

# Config dir holding your work Team seat OAuth session.
#
# We default to ~/.aklaude (a dedicated dir) rather than ~/.claude so this
# project's runtime cleanly isolates your work Team seat from any personal
# Claude account you may already be logged into in ~/.claude. The two seats
# stay independent — switching between them is just a matter of which
# CLAUDE_CONFIG_DIR is active.
#
# First-time setup (one-time, see README First-time setup):
#   CLAUDE_CONFIG_DIR=~/.aklaude claude
#   > /login
#
# Override only if your work Team seat session already lives elsewhere.
CLAUDE_CONFIG_DIR=~/.aklaude

# Default model when the optimizer's runtime adapter is invoked without a
# SKILL.md `model:` declaration. SKILL.md frontmatter takes precedence.
OPTIMIZER_MODEL=claude-haiku-4-5
